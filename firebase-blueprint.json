{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered user profile",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique user ID (from Firebase Auth)" },
        "email": { "type": "string", "description": "Email address of the user" },
        "displayName": { "type": "string", "description": "Name shown to other users" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "role": { "type": "string", "enum": ["citizen", "inspector"], "description": "User role inside the platform" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["id", "email"]
    },
    "Issue": {
      "title": "Issue",
      "description": "A reported civic issue like pothole, leakage, etc.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique issue reporting ID" },
        "userId": { "type": "string", "description": "ID of reporting citizen" },
        "imageUrl": { "type": "string", "description": "URL of uploaded proof image" },
        "issueType": {
          "type": "string",
          "enum": [
            "Pothole",
            "Water Leakage",
            "Streetlight Damage",
            "Garbage Accumulation",
            "Road Damage",
            "Traffic Obstruction",
            "Other"
          ],
          "description": "Category of the civic problem"
        },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"], "description": "Urgency and extent of the issue" },
        "description": { "type": "string", "description": "Detailed description generated by Gemini or entered by user" },
        "priorityScore": { "type": "number", "description": "AI generated priority rank (e.g. 0-100)" },
        "recommendedDepartment": { "type": "string", "description": "Suggested public department responsible" },
        "status": { "type": "string", "enum": ["Reported", "Under Review", "In Progress", "Resolved"], "description": "Status of the civic action" },
        "location": { "type": "string", "description": "Manually entered or GPS location" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of report submission" },
        "executiveSummary": { "type": "string", "description": "A concise executive briefing under 50 words" },
        "consequenceForecast": {
          "type": "object",
          "description": "AI-generated realistic, consequence-focused estimates if unresolved",
          "properties": {
            "sevenDayForecast": { "type": "string", "description": "Forecasted impact in 7 days" },
            "thirtyDayForecast": { "type": "string", "description": "Forecasted impact in 30 days" },
            "ninetyDayForecast": { "type": "string", "description": "Forecasted impact in 90 days" },
            "forecastConfidence": { "type": "string", "enum": ["Low", "Medium", "High"], "description": "Confidence of the forecast" },
            "forecastSummary": { "type": "string", "description": "Overview of forecast consequence projection" }
          },
          "required": ["sevenDayForecast", "thirtyDayForecast", "ninetyDayForecast", "forecastConfidence", "forecastSummary"]
        }
      },
      "required": ["id", "userId", "imageUrl", "issueType", "severity", "priorityScore", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Citizens and administrator details mapped by Auth UID"
    },
    "/issues/{issueId}": {
      "schema": "Issue",
      "description": "Global collection of reports with status tracking"
    }
  }
}
